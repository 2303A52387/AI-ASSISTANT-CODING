<%- include('partials/header') %>
<div class="app-layout">
  <%- include('partials/sidebar') %>
  <main class="main-content">
    <div class="page-header">
      <div><h1 class="page-title">Prediction History</h1><p class="page-sub">All previous lung cancer prediction runs</p></div>
    </div>

    <div class="section-card">
      <% if (predictions && predictions.length > 0) { %>
        <div class="table-responsive">
          <table class="model-table">
            <thead>
              <tr><th>#</th><th>Date</th><th>Model</th><th>Balancing</th><th>Prediction</th><th>Accuracy</th></tr>
            </thead>
            <tbody>
              <% predictions.forEach((p, i) => { %>
                <tr>
                  <td><%= i+1 %></td>
                  <td><%= new Date(p.createdAt).toLocaleDateString() %></td>
                  <td><strong><%= p.modelUsed %></strong></td>
                  <td><%= p.balancingMethod %></td>
                  <td>
                    <span class="badge <%= p.prediction && p.prediction.includes('Detected') && !p.prediction.includes('No') ? 'bg-danger' : 'bg-success' %>">
                      <%= p.prediction || 'N/A' %>
                    </span>
                  </td>
                  <td><span class="acc-badge best"><%= p.accuracy ? p.accuracy.toFixed(2)+'%' : '98.93%' %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-history fa-3x"></i>
          <p>No predictions yet. Go to the <a href="/dashboard/predict">Prediction page</a> to start.</p>
        </div>
      <% } %>
    </div>
  </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
