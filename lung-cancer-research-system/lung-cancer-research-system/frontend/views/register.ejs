<%- include('partials/header') %>

<div class="auth-page">
  <div class="auth-left">
    <div class="auth-left-content">
      <div class="auth-logo"><i class="fas fa-lungs"></i></div>
      <h1>Join the Research</h1>
      <p>Create your researcher account to access cutting-edge lung cancer detection tools powered by CTGAN and Random Forest.</p>
      <div class="feature-list">
        <div class="feature-item"><i class="fas fa-check-circle"></i> CTGAN Synthetic Data Generation</div>
        <div class="feature-item"><i class="fas fa-check-circle"></i> 10 ML Classifier Comparison</div>
        <div class="feature-item"><i class="fas fa-check-circle"></i> 98.93% Detection Accuracy</div>
        <div class="feature-item"><i class="fas fa-check-circle"></i> 5-Fold Cross Validation</div>
      </div>
    </div>
  </div>

  <div class="auth-right">
    <div class="auth-card">
      <h2>Create Account</h2>
      <p class="auth-subtitle">Start your lung cancer research journey</p>

      <% if (error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger"><i class="fas fa-exclamation-circle"></i> <%= error_msg %></div>
      <% } %>

      <form action="/register" method="POST">
        <div class="form-group">
          <label>Full Name</label>
          <div class="input-icon">
            <i class="fas fa-user"></i>
            <input type="text" name="name" class="form-control" placeholder="Dr. John Smith" required/>
          </div>
        </div>
        <div class="form-group">
          <label>Email Address</label>
          <div class="input-icon">
            <i class="fas fa-envelope"></i>
            <input type="email" name="email" class="form-control" placeholder="researcher@university.edu" required/>
          </div>
        </div>
        <div class="form-group">
          <label>Institution</label>
          <div class="input-icon">
            <i class="fas fa-university"></i>
            <input type="text" name="institution" class="form-control" placeholder="University / Research Center"/>
          </div>
        </div>
        <div class="form-group">
          <label>Password</label>
          <div class="input-icon">
            <i class="fas fa-lock"></i>
            <input type="password" name="password" class="form-control" placeholder="Min. 6 characters" required/>
          </div>
        </div>
        <div class="form-group">
          <label>Confirm Password</label>
          <div class="input-icon">
            <i class="fas fa-lock"></i>
            <input type="password" name="password2" class="form-control" placeholder="Repeat password" required/>
          </div>
        </div>
        <button type="submit" class="btn-auth">Create Account <i class="fas fa-user-plus"></i></button>
      </form>
      <p class="auth-link">Already have an account? <a href="/login">Sign in</a></p>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body></html>
