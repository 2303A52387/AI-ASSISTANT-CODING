<%- include('partials/header') %>
<div class="app-layout">
  <%- include('partials/sidebar') %>
  <main class="main-content">
    <div class="page-header">
      <div><h1 class="page-title">Data Preprocessing</h1><p class="page-sub">Handle missing values, normalize features, and explore dataset statistics</p></div>
    </div>

    <div class="row">
      <div class="col-lg-4">
        <div class="section-card">
          <div class="section-head"><h3>Preprocessing Steps</h3></div>
          <div class="steps-list">
            <div class="step-item done"><i class="fas fa-check-circle"></i><div><strong>Categorical Encoding</strong><p>Gender: M→1, F→0 · Lung Cancer: YES→1, NO→0</p></div></div>
            <div class="step-item done"><i class="fas fa-check-circle"></i><div><strong>Missing Value Check</strong><p>Dataset contains 0 missing values</p></div></div>
            <div class="step-item done"><i class="fas fa-check-circle"></i><div><strong>Class Imbalance Detection</strong><p>Cancer: 270 (87.4%) · Normal: 39 (12.6%)</p></div></div>
            <div class="step-item done"><i class="fas fa-check-circle"></i><div><strong>Feature Scaling</strong><p>Standardization applied to numerical features</p></div></div>
            <div class="step-item done"><i class="fas fa-check-circle"></i><div><strong>Train/Test Split</strong><p>80% Training · 20% Testing · random_state=42</p></div></div>
            <div class="step-item done"><i class="fas fa-check-circle"></i><div><strong>Feature Selection</strong><p>Chi-Square Test for feature significance</p></div></div>
          </div>
        </div>
      </div>

      <div class="col-lg-8">
        <div class="section-card">
          <div class="section-head"><h3>Dataset Overview</h3></div>
          <div class="stats-grid-lg">
            <div class="stat-box"><i class="fas fa-table"></i><span class="sb-val">309</span><span class="sb-lbl">Total Instances</span></div>
            <div class="stat-box"><i class="fas fa-columns"></i><span class="sb-val">16</span><span class="sb-lbl">Attributes</span></div>
            <div class="stat-box"><i class="fas fa-virus"></i><span class="sb-val">270</span><span class="sb-lbl">Cancer Cases</span></div>
            <div class="stat-box"><i class="fas fa-heart"></i><span class="sb-val">39</span><span class="sb-lbl">Normal Cases</span></div>
          </div>

          <div class="mt-4">
            <h5>Feature Descriptions</h5>
            <div class="feature-table-wrap">
              <table class="feature-table">
                <thead><tr><th>Feature</th><th>Type</th><th>Description</th><th>Values</th></tr></thead>
                <tbody>
                  <% const features = [
                    ['Gender','Categorical','Patient biological sex','M / F → 1 / 0'],
                    ['Age','Numerical','Patient age in years','18 – 87'],
                    ['Smoking','Binary','Smoking habit indicator','1 / 2'],
                    ['Yellow Fingers','Binary','Yellowing of fingers','1 / 2'],
                    ['Anxiety','Binary','Anxiety level indicator','1 / 2'],
                    ['Peer Pressure','Binary','Social pressure factor','1 / 2'],
                    ['Chronic Disease','Binary','Chronic disease presence','1 / 2'],
                    ['Fatigue','Binary','Level of fatigue','1 / 2'],
                    ['Allergy','Binary','Allergy presence','1 / 2'],
                    ['Wheezing','Binary','Wheezing symptom','1 / 2'],
                    ['Alcohol','Binary','Alcohol consumption','1 / 2'],
                    ['Coughing','Binary','Coughing symptom','1 / 2'],
                    ['Shortness of Breath','Binary','Breathing difficulty','1 / 2'],
                    ['Swallowing Difficulty','Binary','Swallowing issues','1 / 2'],
                    ['Chest Pain','Binary','Chest pain experience','1 / 2'],
                    ['Lung Cancer','Target','Class label','YES / NO → 1 / 0'],
                  ]; %>
                  <% features.forEach(([name, type, desc, vals]) => { %>
                    <tr>
                      <td><strong><%= name %></strong></td>
                      <td><span class="type-badge type-<%= type.toLowerCase() %>"><%= type %></span></td>
                      <td><%= desc %></td>
                      <td><code><%= vals %></code></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <div class="section-card mt-3">
          <div class="section-head"><h3>Class Imbalance Analysis</h3></div>
          <div class="imbalance-alert">
            <i class="fas fa-exclamation-triangle"></i>
            <div>
              <strong>Severe Class Imbalance Detected</strong>
              <p>270 Cancer (87.4%) vs 39 Normal (12.6%). Applied CTGAN, SMOTE, Borderline-SMOTE, and SMOTE-ENN to address this issue.</p>
            </div>
          </div>
          <canvas id="imbalanceChart" height="120"></canvas>
        </div>
      </div>
    </div>
  </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
new Chart(document.getElementById('imbalanceChart'), {
  type: 'bar',
  data: {
    labels: ['Original (Imbalanced)', 'After SMOTE', 'After CTGAN'],
    datasets: [
      { label: 'Cancer', data: [270, 270, 270], backgroundColor: '#ef4444' },
      { label: 'Normal', data: [39, 270, 270], backgroundColor: '#22c55e' }
    ]
  },
  options: {
    responsive: true, plugins: { legend: { position: 'top' } },
    scales: { x: { stacked: false }, y: { beginAtZero: true } }
  }
});
</script>
</body></html>
